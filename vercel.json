{
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm install --force",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "NODE_VERSION": "18.x"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--max_old_space_size=4096"
    }
  }
} 